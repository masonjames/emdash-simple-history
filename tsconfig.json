{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"verbatimModuleSyntax": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"lib": ["ES2022", "DOM"],
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
